        "jsCode": "const input = $input.first().json;\nconst mappingEntries = Object.entries(input.column_mapping || {});\nmappingEntries.sort((a, b) => a[0].localeCompare(b[0]));\nconst readableMapping = {};\nmappingEntries.forEach(([header, dbCol]) => {\n  readableMapping[header] = dbCol;\n});\nreturn {\n  id: input.dataset_id,\n  name: input.dataset_name,\n  summary: input.dataset_summary || '',\n  column_mapping: readableMapping,\n  dataset_desc: input.dataset_desc,\n  sample_questions: input.sample_questions,\n};"
