    {
      "parameters": {
        "jsCode": "// Loop through all items passed to the Code node\nconst items = $input.all();\n\nreturn items.map(item => {\n  const data = item.json;\n\n  // Extract the target fields with fallbacks\n  const name = data.dataset_name || \"Unknown Dataset\";\n  const desc = data.dataset_desc || \"No description provided.\";\n  const summary = data.dataset_summary || \"\";\n\n  // 1. Construct the optimal embedding string\n  // Using clear labels helps the embedding model understand the context of the text\n  const textToEmbed = `Dataset Name: ${name}\\nDescription: ${desc}\\nSchema and Business Logic:\\n${summary}`.trim();\n\n  // 2. Return the structured payload\n  return {\n    json: {\n      // This is the string you will map to your embedding node\n      embedding_text: textToEmbed,\n      \n      // Preserve essential fields as metadata to attach to the vector \n      // This allows your AI agent to retrieve the ID and exact routing info later\n      metadata: {\n        dataset_id: data.dataset_id,\n        dataset_name: name,\n        dataset_desc: desc,\n        owner_email: data.owner_email\n      }\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
